<Window x:Class="OzzContextGen.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:OzzContextGen.WPF.ViewModels"
        xmlns:i18n="clr-namespace:OzzContextGen.i18n;assembly=OzzContextGen.i18n"
        xmlns:local="clr-namespace:OzzContextGen.WPF"
        mc:Ignorable="d"
        Title="OzzContextGen - LLM Context Packer" Height="800" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- Üst Seçim Alanı -->
            <RowDefinition Height="*"/>
            <!-- Ana Dosya Listesi (DataGrid) -->
            <RowDefinition Height="Auto"/>
            <!-- Alt İşlem Butonları -->
            <RowDefinition Height="Auto"/>
            <!-- Durum Çubuğu (Status Bar) -->
        </Grid.RowDefinitions>
        <ToolBar Grid.Row="0">
            <Button Style="{StaticResource IconButtonStyle-28x24}"
                    ToolTip="{x:Static i18n:LocalizedStrings.OpenProfile}"
                    Command="{Binding OpenProfileCommand}">
                <Viewbox Width="18" Height="18">
                    <Path Margin="0">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Fill" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                <Setter Property="Data" Value="{StaticResource folder2-open}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                        <Setter Property="Fill" Value="#808890"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource {x:Static SystemColors.ActiveCaptionTextBrushKey}}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Viewbox>
            </Button>
        </ToolBar>
        <!-- 1. ÜST SEÇİM ALANI (Klasör ve Profil Seçimleri) -->
        <GroupBox Header="Profil ve Dizin Ayarları" Grid.Row="1" Padding="5" Margin="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Kaynak Klasör -->
                <TextBlock Text="{x:Static i18n:LocalizedStrings.SourceFolder}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>
                <Button Content="{x:Static i18n:LocalizedStrings.Browse}" Command="{Binding BrowseSourceCommand}" Grid.Row="0" Grid.Column="2" Padding="10,2" Margin="5"/>

                <!-- Profil Dosyası (.ctxgen) -->
                <TextBlock Text="{x:Static i18n:LocalizedStrings.ProfileFile}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox Text="{Binding ProfilePath, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>
                <Button Content="{x:Static i18n:LocalizedStrings.OpenCreate}" Command="{Binding OpenProfileCommand}"
                        Grid.Row="1" Grid.Column="2" Padding="10,2" Margin="5" ToolTip="{x:Static i18n:LocalizedStrings.OpenProfile}"/>

                <!-- Çıktı Dosyası (.md) -->
                <TextBlock Text="{x:Static i18n:LocalizedStrings.OutputFile}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>
                <Button Content="{x:Static i18n:LocalizedStrings.SelectTarget}" Command="{Binding BrowseOutputCommand}" Grid.Row="2" Grid.Column="2" Padding="10,2" Margin="5"/>
            </Grid>
        </GroupBox>

        <!-- 2. ANA DOSYA LİSTESİ (DataGrid) -->
        <Grid Grid.Row="2" Margin="6">
            <DataGrid AlternatingRowBackground="#F5F5F5" GridLinesVisibility="Horizontal"
                      ItemsSource="{Binding TrackedFiles}"
                      SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                      AutoGenerateColumns="False" CanUserAddRows="False">
                <DataGrid.Columns>
                    <!-- Seçim Checkbox'ı -->
                    <DataGridCheckBoxColumn Header="{x:Static i18n:LocalizedStrings.Pack}" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="70"/>

                    <!-- Değişim Tipi (Yeni, Değişti, Aynı vb.) -->
                    <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Status}" Binding="{Binding ChangeType}" Width="100" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="New">
                                        <Setter Property="Foreground" Value="Green"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Trigger>
                                    <Trigger Property="Text" Value="Modified">
                                        <Setter Property="Foreground" Value="OrangeRed"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Trigger>
                                    <Trigger Property="Text" Value="Deleted">
                                        <Setter Property="Foreground" Value="Gray"/>
                                        <Setter Property="FontStyle" Value="Italic"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Göreceli Dosya Yolu -->
                    <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.FilePath}" Binding="{Binding RelativePath}" Width="*" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- 3. ALT İŞLEM BUTONLARI -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="3" Margin="0,0,0,10">
            <Button Content="{x:Static i18n:LocalizedStrings.AnalyzeChanges}" Command="{Binding AnalyzeChangesCommand}" Padding="20,5" Margin="5,0"/>
            <Button Content="{x:Static i18n:LocalizedStrings.PackContext}"
                    Command="{Binding PackCommand}"
                    Padding="20,5" Margin="5,0" FontWeight="Bold">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#007ACC"/>
                        <Setter Property="Foreground" Value="#F8F8F8"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                                <Setter Property="Foreground" Value="#A0A0A0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- 4. DURUM ÇUBUĞU (Status Bar) -->
        <StatusBar Grid.Row="4" Background="#EEEEEE">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>

</Window>
