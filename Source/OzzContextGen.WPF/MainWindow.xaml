<Window x:Class="OzzContextGen.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:OzzContextGen.WPF.ViewModels"
        xmlns:i18n="clr-namespace:OzzContextGen.i18n;assembly=OzzContextGen.i18n"
        xmlns:local="clr-namespace:OzzContextGen.WPF"
        xmlns:helpers="clr-namespace:OzzContextGen.WPF.Helpers"
        mc:Ignorable="d"
        Title="OzzContextGen - LLM Context Packer" Width="800" Height="800" MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <helpers:BindingProxy x:Key="proxy" Data="{Binding}"/>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- Üst Seçim Alanı -->
            <RowDefinition Height="*"/>
            <!-- Ana Dosya Listesi (DataGrid) -->
            <RowDefinition Height="Auto"/>
            <!-- Durum Çubuğu (Status Bar) -->
        </Grid.RowDefinitions>
        <ToolBar Grid.Row="0">
            <Button Style="{StaticResource IconButtonStyle-28x24}"
                    ToolTip="{x:Static i18n:LocalizedStrings.OpenProfile}"
                    Command="{Binding OpenProfileCommand}">
                <Viewbox Width="18" Height="18">
                    <Path Margin="0">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Fill" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                <Setter Property="Data" Value="{StaticResource folder2-open}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                        <Setter Property="Fill" Value="#808890"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource {x:Static SystemColors.ActiveCaptionTextBrushKey}}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Viewbox>
            </Button>
            <Button Style="{StaticResource IconButtonStyle-28x24}"
                    Command="{Binding AnalyzeChangesCommand}"
                    ToolTip="{x:Static i18n:LocalizedStrings.AnalyzeChanges}">
                <Viewbox Width="18" Height="18">
                    <Path Margin="0">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Fill" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                <Setter Property="Data" Value="{StaticResource arrow-repeat}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                        <Setter Property="Fill" Value="#808890"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource {x:Static SystemColors.ActiveCaptionTextBrushKey}}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Viewbox>
            </Button>
            <Button Style="{StaticResource IconButtonStyle-38x24}"
                    Command="{Binding RemoveDeletedFilesCommand}"
                    ToolTip="{x:Static i18n:LocalizedStrings.RemoveDeletedFiles}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" >
                    <Viewbox Width="15" Height="15">
                        <Path Margin="1,-2,-1,0" RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="-45"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Path.RenderTransform>
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                    <Setter Property="Data" Value="{StaticResource file-earmark-x}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                            <Setter Property="Fill" Value="#808890"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource {x:Static SystemColors.ActiveCaptionTextBrushKey}}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Viewbox>
                    <Viewbox Width="18" Height="18">
                        <Path Margin="-4,0,0,0">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                    <Setter Property="Data" Value="{StaticResource trash}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                            <Setter Property="Fill" Value="#808890"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource {x:Static SystemColors.ActiveCaptionTextBrushKey}}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Viewbox>
                </StackPanel>
            </Button>
            <Button x:Name="PackButton" Padding="8,3" Margin="3,0" FontWeight="Bold"
                    Command="{Binding PackCommand}"
                    ToolTip="{x:Static i18n:LocalizedStrings.PackContext}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#007ACC"/>
                        <Setter Property="Foreground" Value="#F0F0F0"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                                <Setter Property="Foreground" Value="#007ACC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#A0A0A0"/>
                                <Setter Property="Foreground" Value="#D8D8D8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{x:Static i18n:LocalizedStrings.Pack}" Margin="0,0,4,0"/>
                    <Viewbox Width="18" Height="18">
                        <Path Margin="2,0,0,0">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="{Binding Foreground, ElementName=PackButton}"/>
                                    <Setter Property="Data" Value="{StaticResource box-seam-fill}"/>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Viewbox>
                </StackPanel>
            </Button>
        </ToolBar>
        <!-- 1. ÜST SEÇİM ALANI (Klasör ve Profil Seçimleri) -->
        <GroupBox Header="Profil ve Dizin Ayarları" Grid.Row="1" Padding="5" Margin="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Kaynak Klasör -->
                <TextBlock Text="{x:Static i18n:LocalizedStrings.SourceFolder}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>
                <Button Content="{x:Static i18n:LocalizedStrings.Browse}" Command="{Binding BrowseSourceCommand}" Grid.Row="0" Grid.Column="2" Padding="10,2" Margin="5"/>

                <!-- Profil Dosyası (.ctxgen) -->
                <TextBlock Text="{x:Static i18n:LocalizedStrings.ProfileFile}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox Text="{Binding ProfilePath, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>
                <Button Content="{x:Static i18n:LocalizedStrings.OpenCreate}" Command="{Binding OpenProfileCommand}"
                        Grid.Row="1" Grid.Column="2" Padding="10,2" Margin="5" ToolTip="{x:Static i18n:LocalizedStrings.OpenProfile}"/>

                <!-- Çıktı Dosyası (.md) -->
                <TextBlock Text="{x:Static i18n:LocalizedStrings.OutputFile}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>
                <Button Content="{x:Static i18n:LocalizedStrings.SelectTarget}" Command="{Binding BrowseOutputCommand}" Grid.Row="2" Grid.Column="2" Padding="10,2" Margin="5"/>
            </Grid>
        </GroupBox>

        <!-- DataGrid & Detail Panel -->
        <Grid Grid.Row="2" Margin="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <DataGrid x:Name="FileGrid" AlternatingRowBackground="#F5F5F5" GridLinesVisibility="Horizontal"
                      ItemsSource="{Binding TrackedFiles}"
                      SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                      AutoGenerateColumns="False" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="80">
                        <DataGridCheckBoxColumn.Header>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="{x:Static i18n:LocalizedStrings.Pack}" />
                                <CheckBox Margin="4,0,0,0"
                                          IsChecked="{Binding Data.IsAllSelected, Source={StaticResource proxy}, Mode=OneWay}"
                                          Command="{Binding Data.ToggleAllSelectedCommand, Source={StaticResource proxy}}" IsThreeState="True" />
                            </StackPanel>
                        </DataGridCheckBoxColumn.Header>

                    </DataGridCheckBoxColumn>
                    <DataGridComboBoxColumn Header="{x:Static i18n:LocalizedStrings.PackingMode}"
                                            SelectedValueBinding="{Binding PackingMode, Mode=TwoWay}"
                                            DisplayMemberPath="DisplayValue"
                                            SelectedValuePath="Value"
                                            ItemsSource="{Binding Data.PackingModeModeValues, Source={StaticResource proxy}}"
                                            Width="96"/>
                    <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.Status}"
                                        Binding="{Binding ChangeType}" Width="100" IsReadOnly="True"
                                        ElementStyle="{StaticResource StatusTextBlockStyle}"/>
                    <DataGridTextColumn Header="{x:Static i18n:LocalizedStrings.FilePath}"
                                        Binding="{Binding RelativePath}" Width="*" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
            <Border Grid.Column="1" Margin="2,0" Padding="6" DataContext="{Binding SelectedFile}"
                    Background="#F0F0F0" BorderBrush="#484848" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{x:Static i18n:LocalizedStrings.FilePath}" Grid.Row="0" Grid.Column="0" FontWeight="Bold" Margin="0,2"/>
                    <TextBlock Text=":" Grid.Row="0" Grid.Column="1" Margin="2"/>
                    <TextBlock Text="{Binding RelativePath}" Grid.Row="0" Grid.Column="2" Background="White" Padding="4,2,0,2" Margin="1"/>

                    <TextBlock Text="{x:Static i18n:LocalizedStrings.Status}" Grid.Row="1" Grid.Column="0" FontWeight="Bold" Margin="0,2"/>
                    <TextBlock Text=":" Grid.Row="1" Grid.Column="1" Margin="2"/>
                    <TextBlock Text="{Binding ChangeType}" Grid.Row="1" Grid.Column="2" Background="White" Padding="4,2,0,2" Margin="1"/>

                    <TextBlock Text="{x:Static i18n:LocalizedStrings.FileSize}" Grid.Row="2" Grid.Column="0" FontWeight="Bold" Margin="0,2"/>
                    <TextBlock Text=":" Grid.Row="2" Grid.Column="1" Margin="2"/>
                    <TextBlock Text="{Binding FileSize}" Grid.Row="2" Grid.Column="2" Background="White" Padding="4,2,0,2" Margin="1"/>

                    <TextBlock Text="{x:Static i18n:LocalizedStrings.Pack}" Grid.Row="3" Grid.Column="0" FontWeight="Bold" Margin="0,2"/>
                    <TextBlock Text=":" Grid.Row="3" Grid.Column="1" Margin="2"/>
                    <CheckBox IsChecked="{Binding IsSelected}" Grid.Row="3" Grid.Column="2" Background="White" Margin="0,4"/>

                    <TextBlock Text="{x:Static i18n:LocalizedStrings.ContextNote}" Grid.Row="4" Grid.Column="0" FontWeight="Bold" Margin="0,2"/>
                    <TextBlock Text=":" Grid.Row="4" Grid.Column="1" Margin="2"/>
                    <TextBox Text="{Binding ContextNote}" Grid.Row="4" Grid.Column="2" Margin="1" TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Background="#EEEEEE">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>

</Window>
